<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Applicants</title>
    <link rel="stylesheet" href="/stylesheets/navbar.css">
    <link rel="stylesheet" href="/stylesheets/applicants.css">
</head>

<body>
    <%- include("partials/navbar") %>
        <a href="/recruiter/myjobs">Back</a>
        <div class="applicants-container">
            <h2>Applicants</h2>

            <% if (typeof message !=="undefined" ) { %>
                <p class="message">
                    <%= message %>
                </p>
                <% } %>

                    <% if (applicants.length===0) { %>
                        <p></p>
                        <% } else { %>
                            <div class="applicant-grid">
                                <% applicants.forEach(function(applicant) { %>
                                    <div class="applicant-card">
                                        <h3>
                                            <%= applicant.applicant.fullname %>
                                        </h3>
                                        <p><strong>Email:</strong>
                                            <%= applicant.applicant.email %>
                                        </p>
                                        <p><strong>Status:</strong>
                                            <%= applicant.status %>
                                        </p>

                                        <form class="updateStatusForm" data-applicant-id="<%= applicant._id %>">
                                            <select name="status" class="status" required>
                                                <option value="">Change Status</option>
                                                <option value="pending">Pending</option>
                                                <option value="accepted">Accepted</option>
                                                <option value="rejected">Rejected</option>
                                                <option value="shortlisted">Shortlisted</option>
                                            </select>

                                            <button type="submit">Update Status</button>
                                        </form>
                                    </div>
                                    <% }) %>
                            </div>
                            <% } %>
        </div>
        <script src="/javascripts/updateStatus.js"></script>
</body>

</html>