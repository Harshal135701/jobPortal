<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Jobs - NextHire</title>
    <link rel="stylesheet" href="/stylesheets/alljobs.css">
    <link rel="stylesheet" href="/stylesheets/navbar.css">
</head>

<body>
    <%- include("partials/navbar")%>
    <div class="page-container">
        <h1 class="page-title">Available <span>Jobs</span></h1>

        <div class="jobs-container">
            <% if (jobs.length===0) { %>
                <p>No jobs available right now.</p>
                <% } else { %>
                    <% jobs.forEach(job=> { %>
                        <div class="job-card">
                            <h2>
                                <%= job.title %>
                            </h2>
                            <p><strong>Company:</strong>
                                <%= job.company %>
                            </p>
                            <p><strong>Salary:</strong> ₹<%= job.salary %>
                            </p>
                            <p><strong>Location:</strong>
                                <%= job.location %>
                            </p>
                            <a href="/jobs/<%= job._id %>" class="details-btn">
                                View Details
                            </a>
                        </div>
                        <% }) %>
                            <% } %>
        </div>
    </div>
</body>

</html>