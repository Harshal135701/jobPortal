<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Jobs - NextHire</title>
    <link rel="stylesheet" href="/stylesheets/alljobs.css">
    <link rel="stylesheet" href="/stylesheets/navbar.css">
</head>

<body>

    <%- include("partials/navbar") %>

        <div class="page-container">

            <h1 class="page-title">Available <span>Jobs</span></h1>

            <!-- Controls -->
            <div class="controls-bar">

                <form action="/jobs/alljobs" method="GET" class="search-form">
                    <input type="text" name="keyword" placeholder="Search jobs..." value="<%= keyword || '' %>">

                    <select name="location">
                        <option value="">All Locations</option>
                        <option value="Mumbai" <%=location==="Mumbai" ? "selected" : "" %>>Mumbai</option>
                        <option value="Nashik" <%=location==="Nashik" ? "selected" : "" %>>Nashik</option>
                        <option value="Bangalore" <%=location==="Bangalore" ? "selected" : "" %>>Bangalore</option>
                        <option value="Delhi" <%=location==="Delhi" ? "selected" : "" %>>Delhi</option>
                        <option value="Pune" <%=location==="Pune" ? "selected" : "" %>>Pune</option>
                    </select>

                    <select name="jobType">
                        <option value="">All Job Types</option>
                        <option value="Full-time" <%=jobType==="Full-time" ? "selected" :""%>>Full-time</option>
                        <option value="Part-time" <%=jobType==="Part-time" ? "selected" :""%>>Part-time</option>
                        <option value="Internship" <%=jobType==="Internship" ? "selected" :""%>>Internship</option>
                        <option value="Remote" <%=jobType==="Remote" ? "selected" :""%>>Remote</option>
                    </select>

                    <select name="experienceLevel">
                        <option value="">Experience</option>
                        <option value="0" <%=experienceLevel=="0" ? "selected" : "" %>>Fresher</option>
                        <option value="1" <%=experienceLevel=="1" ? "selected" : "" %>>1+ Years</option>
                        <option value="2" <%=experienceLevel=="2" ? "selected" : "" %>>2+ Years</option>
                        <option value="3" <%=experienceLevel=="3" ? "selected" : "" %>>3+ Years</option>
                    </select>

                    <input type="number" name="salary" placeholder="Min Salary (₹)" value="<%=salary || "" %>">

                    <input type="hidden" name="category" value="<%= category || '' %>">
                    <input type="hidden" name="sort" value="<%= sort || '' %>">
                    <button type="submit">Search</button>
                </form>

                <form action="/jobs/alljobs" method="GET" class="sort-form">
                    <input type="hidden" name="keyword" value="<%= keyword || '' %>">
                    <input type="hidden" name="category" value="<%= category || '' %>">
                    <input type="hidden" name="location" value="<%= location || '' %>">
                    <input type="hidden" name="jobType" value="<%= jobType || '' %>">
                    <input type="hidden" name="salary" value="<%= salary || '' %>">
                    <input type="hidden" name="experienceLevel" value="<%= experienceLevel || '' %>">

                    <select name="sort" onchange="this.form.submit()">
                        <option value="">Sort By</option>
                        <option value="latest" <%=sort==='latest' ? 'selected' : '' %>>Latest</option>
                        <option value="salary_high" <%=sort==='salary_high' ? 'selected' : '' %>>High Salary</option>
                        <option value="salary_low" <%=sort==='salary_low' ? 'selected' : '' %>>Low Salary</option>
                    </select>
                    <a href="/jobs/alljobs" class="clear-btn">Clear</a>
                </form>

            </div>

            <!-- Jobs -->
            <div class="jobs-container">
                <% if (jobs.length===0) { %>
                    <div class="empty-state">No jobs available right now !</div>
                    <% } else { %>

                        <% jobs.forEach(job=> { %>
                            <div class="job-card">

                                <div class="job-info">
                                    <h2>
                                        <%= job.title %>
                                    </h2>
                                    <p><strong>Company:</strong>
                                        <%= job.company %>
                                    </p>
                                    <p><strong>Salary:</strong> ₹<%= job.salary %>
                                    </p>
                                    <p><strong>Location:</strong>
                                        <%= job.location %>
                                    </p>
                                </div>

                                <div class="card-actions">
                                    <a href="/jobs/<%= job._id %>" class="details-btn">View Details</a>

                                    <button
                                        class="bookmark-btn <%= bookmarkedJobs && bookmarkedJobs.some(id => id && id.toString() === job._id.toString()) ? 'saved' : '' %>"
                                        data-id="<%= job._id %>">
                                        <!-- This is checking thaat the bookmarked is exist or not or it is exist the job id matches to bookmarked id if yes(Implice) class saved othewise not  -->

                                        <%= bookmarkedJobs && bookmarkedJobs.some(id=> id && id.toString() ===
                                            job._id.toString())
                                            ? "Saved"
                                            : "Save Job" %>
                                    </button>
                                </div>

                            </div>
                            <% }) %>

                                <% } %>
            </div>

            <!-- Pagination -->
            <% if (totalPages> 0) { %>
                <div class="pagination">

                    <% if (currentPage> 1) { %>
                        <a
                            href="/jobs/alljobs?page=<%= currentPage -1 %>&keyword=<%= keyword || '' %>&category=<%= category || ''%>&location=<%=location || ''%>&salary=<%=salary || ''%>&jobType=<%=jobType || ''%>&experienceLevel=<%=experienceLevel || ""%>">←</a>
                        <% } else { %>
                            <span class="disabled">←</span>
                            <% } %>

                                <% for (let i=1; i <=totalPages; i++) { %>
                                    <% if (i===currentPage) { %>
                                        <span class="active">
                                            <%= i %>
                                        </span>
                                        <% } else { %>
                                            <a
                                                href="/jobs/alljobs?page=<%= i %>&keyword=<%= keyword || '' %>&category=<%= category || '' %>&location=<%=location || ''%>&salary=<%=salary || ''%>&jobType=<%=jobType || ''%>&experienceLevel=<%=experienceLevel || ""%>">
                                                <%= i %>
                                            </a>
                                            <% } %>
                                                <% } %>

                                                    <% if (currentPage < totalPages) { %>
                                                        <a
                                                            href="/jobs/alljobs?page=<%= currentPage + 1 %>&keyword=<%= keyword || '' %>&category=<%= category || '' %>&location=<%=location || ''%>&salary=<%=salary || ''%>&jobType=<%=jobType || ''%>&experienceLevel=<%=experienceLevel || ""%>">→</a>
                                                        <% } else { %>
                                                            <span class="disabled">→</span>
                                                            <% } %>

                </div>
                <% } %>

        </div>

        <script src="/javascripts/alljobs.js"></script>
</body>

</html>