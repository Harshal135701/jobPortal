<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Jobs - NextHire</title>
    <link rel="stylesheet" href="/stylesheets/alljobs.css">
    <link rel="stylesheet" href="/stylesheets/navbar.css">
</head>

<body>
    <%- include("partials/navbar") %>

        ```
        <div class="page-container">
            <h1 class="page-title">Available <span>Jobs</span></h1>


            <div class="controls-bar">


                <!-- 🔍 Search -->
                <form action="/jobs/alljobs" method="GET" class="search-form">

                    <input type="text" name="keyword" placeholder="Search jobs..." value="<%= keyword || '' %>">

                    <input type="hidden" name="category" value="<%= category || '' %>">
                    <input type="hidden" name="sort" value="<%= sort || '' %>">

                    <button type="submit">Search</button>
                </form>

                <!-- 🎯 Sort -->
                <form action="/jobs/alljobs" method="GET" class="sort-form">

                    <input type="hidden" name="keyword" value="<%= keyword || '' %>">
                    <input type="hidden" name="category" value="<%= category || '' %>">

                    <select name="sort" onchange="this.form.submit()">
                        <!-- onchange triggered when the value is modified  -->

                        <option value="">Sort By</option>

                        <option value="latest" <%=sort==='latest' ? 'selected' : '' %>>
                            Latest Jobs
                        </option>

                        <option value="salary_high" <%=sort==='salary_high' ? 'selected' : '' %>>
                            Salary: High → Low
                        </option>

                        <option value="salary_low" <%=sort==='salary_low' ? 'selected' : '' %>>
                            Salary: Low → High
                        </option>

                    </select>

                </form>

            </div>

            <!--  -->
            <!--  -->
            <div class="jobs-container">
                <% if (jobs.length===0) { %>
                    <p>No jobs available right now.</p>
                    <% } else { %>
                        <% jobs.forEach(job=> { %>
                            <div class="job-card">
                                <h2>
                                    <%= job.title %>
                                </h2>
                                <p><strong>Company:</strong>
                                    <%= job.company %>
                                </p>
                                <p><strong>Salary:</strong> ₹<%= job.salary %>
                                </p>
                                <p><strong>Location:</strong>
                                    <%= job.location %>
                                </p>

                                <a href="/jobs/<%= job._id %>" class="details-btn">
                                    View Details
                                </a>
                            </div>
                            <% }) %>
                                <% } %>
            </div>


            <%if(totalPages >0){%>
                <!-- 🔥 Pagination -->
                <div class="pagination">

                    <% if (currentPage> 1) { %>
                        <a
                            href="/jobs/alljobs?page=<%= currentPage -1 %>&keyword=<%= keyword || '' %>&category=<%= category || '' %>">
                            ←
                        </a>
                        <% } else { %>
                            <span class="disabled">←</span>
                            <% } %>

                                <% for(let i=1; i <=totalPages; i++) { %>
                                    <% if(i===currentPage) { %>
                                        <span class="active">
                                            <%= i %>
                                        </span>
                                        <% } else { %>
                                            <a
                                                href="/jobs/alljobs?page=<%= i %>&keyword=<%= keyword || '' %>&category=<%= category || '' %>">
                                                <%= i %>
                                            </a>
                                            <% } %>
                                                <% } %>

                                                    <% if (currentPage < totalPages) { %>
                                                        <a
                                                            href="/jobs/alljobs?page=<%= currentPage + 1 %>&keyword=<%= keyword || '' %>&category=<%= category || '' %>">
                                                            →
                                                        </a>
                                                        <% } else { %>
                                                            <span class="disabled">→</span>
                                                            <% } %>

                </div>
                <%}%>

        </div>
        ```

</body>

</html>