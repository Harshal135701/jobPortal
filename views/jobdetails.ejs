<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Details - NextHire</title>

    <link rel="stylesheet" href="/stylesheets/jobdetails.css">
    <link rel="stylesheet" href="/stylesheets/navbar.css">
</head>

<body>

    <%- include("partials/navbar") %>

    <div class="details-container">

        <a href="/jobs/alljobs" class="back-link">← Back to Jobs</a>

        <div class="job-card">

            <h1><%= jobpost.title %></h1>

            <div class="job-meta">
                <span class="meta-item"><%= jobpost.company %></span>
                <span class="meta-item"><%= jobpost.location %></span>
            </div>

            <div class="salary-box">
                Salary: ₹<%= jobpost.salary %>
            </div>

            <div class="description-box">
                <p>
                    <strong>Description:</strong><br>
                    <%= jobpost.description %>
                </p>
            </div>

            <div class="recruiter-box">
                <h3>Recruiter Information</h3>

                <p><strong>Name:</strong> <%= recruiter.fullname %></p>
                <p><strong>Occupation:</strong> <%= recruiter.occupation %></p>

                <a class="chat-link" href="/recruiter/chat/<%= jobpost._id %>/<%= recruiter._id %>">
                    💬 Chat With Recruiter
                </a>
            </div>

            <form action="/applications/apply/<%= jobpost._id %>" method="get">
                <button class="apply-btn">Apply Now</button>
            </form>

        </div>
    </div>

</body>

</html>