<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Job Post</title>
    <link rel="stylesheet" href="/stylesheets/navbar.css">
    <link rel="stylesheet" href="/stylesheets/update.css">
</head>

<body>
    <%- include("partials/navbar") %>
        <a href="/recruiter/myjobs">Back</a>
        <div class="container">
            <h2>Update Job Post</h2>

            <form id="updateJobForm">

                <label for="title">Job Title</label>
                <input type="text" id="title" value="<%= job.title %>" required>

                <label for="description">Description</label>
                <textarea id="description" rows="5" required><%= job.description %></textarea>

                <label for="company">Company</label>
                <input type="text" id="company" value="<%= job.company %>" required>

                <label for="location">Location</label>
                <input type="text" id="location" value="<%= job.location %>" required>

                <label for="salary">Salary</label>
                <input type="number" id="salary" value="<%= job.salary %>" required>

                <label for="jobType">Job Type</label>
                <select id="jobType" required>
                    <option value="Full-time" <%=job.jobType==="Full-time" ? "selected" : "" %>>Full-time</option>
                    <option value="Part-time" <%=job.jobType==="Part-time" ? "selected" : "" %>>Part-time</option>
                    <option value="Internship" <%=job.jobType==="Internship" ? "selected" : "" %>>Internship</option>
                    <option value="Remote" <%=job.jobType==="Remote" ? "selected" : "" %>>Remote</option>
                </select>

                <label for="experienceLevel">Experience Level</label>
                <input type="number" id="experienceLevel" value="<%= job.experienceLevel %>" required>

                <button type="submit">Update Job</button>
            </form>
        </div>

        <script>
            document.getElementById("updateJobForm").addEventListener("submit", async function (e) {
                e.preventDefault()
                // Stop the browser default behavior

                const updatedFields = {
                    title: document.getElementById("title").value,
                    description: document.getElementById("description").value,
                    company: document.getElementById("company").value,
                    location: document.getElementById("location").value,
                    salary: document.getElementById("salary").value,
                    jobType: document.getElementById("jobType").value,
                    experienceLevel: document.getElementById("experienceLevel").value
                }
                try {


                    const respose = await fetch("/recruiter/<%=job._id%>/update", {
                        method: "PUT",
                        headers: {
                            "Content-Type": "Application/Json"
                        },
                        body: JSON.stringify(updatedFields)
                    })

                    const data = await respose.json()

                    alert(data.message)

                    if (data.success) {
                        window.location.href = "/recruiter/myjobs";
                    }
                }
                catch (err) {
                    alert("something went wrong");
                }
            })
        </script>
</body>

</html>