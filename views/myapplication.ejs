<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Applications</title>

    <link rel="stylesheet" href="/stylesheets/myapplication.css">
    <link rel="stylesheet" href="/stylesheets/navbar.css">
</head>

<body>

    <%- include("partials/navbar") %>

        <div class="container">

            <!-- Title -->
            <h1>My <span style="color:#6d28d9;">Applications</span></h1>

            <!-- Message -->
            <% if (typeof message !=='undefined' ) { %>
                <p class="message">
                    <%= message %>
                </p>
                <% } %>
                    <form method="get" action="/applications/my" class="filters">

                        <input type="hidden" name="page" value="1">

                        <input type="text" name="search" placeholder="Search jobs..." value="<%= search || '' %>">

                        <select name="sort">
                            <option value="latest" <%=sort==="latest" ?"selected":"" %>>Latest</option>
                            <option value="oldest" <%=sort==="oldest" ?"selected":"" %>>Oldest</option>
                        </select>

                        <select name="status">
                            <option value="all">All</option>
                            <option value="pending" <%=status==="pending" ?"selected":"" %>>Pending</option>
                            <option value="accepted" <%=status==="accepted" ?"selected":"" %>>Accepted</option>
                            <option value="rejected" <%=status==="rejected" ?"selected":"" %>>Rejected</option>
                            <option value="shortlisted" <%=status==="shortlisted" ?"selected":"" %>>Shortlisted</option>
                            <option value="closed" <%=status==="closed" ?"selected":"" %>>Closed</option>
                            <option value="withdrawn" <%=status==="withdrawn" ?"selected":"" %>>Withdrawn</option>
                        </select>

                        <button type="submit">Apply</button>
                        <a href="/applications/my" class="clear-btn">Clear</a>
                    </form>

                    <!-- Empty State -->
                    <% if (applications.length===0) { %>
                        <p class="empty">
                            No applications yet 🚀 <br>
                            <a href="/jobs/alljobs">Explore Jobs</a>
                        </p>
                        <% } else { %>




                            <div class="applications-grid">

                                <% applications.forEach(application=> { %>

                                    <!-- Card -->
                                    <div class="application-card <%= application.job ? '' : 'closed' %>">

                                        <% if (application.job) { %>

                                            <!-- Job Available -->
                                            <h2>
                                                <%= application.job.title %>
                                            </h2>

                                            <p><strong>Company:</strong>
                                                <%= application.job.company || "N/A" %>
                                            </p>
                                            <p><strong>Location:</strong>
                                                <%= application.job.location || "N/A" %>
                                            </p>
                                            <p><strong>Salary:</strong> ₹<%= application.job.salary || "Not disclosed"
                                                    %>
                                            </p>
                                            <p><Strong>Resume :</Strong>
                                                <%if(application.resumeUrl){%>
                                                    <span>Uploaded</span>

                                                    <%}else{%>
                                                        <span>Not Uploaded</span>
                                                        <%}%>
                                            </p>
                                            <p><strong>Applied At:</strong>
                                                <%= new Date(application.createdAt).toLocaleDateString()%>
                                            </p>

                                            <a href="/jobs/<%=application.job._id%>">View job</a>

                                            <!-- Status Badge -->
                                            <p class="status <%= application.status %>">
                                                <%= application.status %>
                                            </p>

                                            <% } else { %>

                                                <!-- Job Deleted -->
                                                <h2>⚠️ Job Closed</h2>
                                                <p>This position is no longer available</p>

                                                <p class="status closed">
                                                    <%= application.status %>
                                                </p>

                                                <% } %>
                                                    <button class="delete-btn" data-id="<%= application._id %>">
                                                        Withdraw
                                                    </button>
                                    </div>

                                    <% }) %>

                            </div>

                            <% } %>

        </div>
        <div class="pagination">

            <% if (page> 1) { %>
                <a class="page-btn"
                    href="?page=<%= page-1 %>&sort=<%= sort %>&status=<%= status %>&search=<%= search %>">
                    ←
                </a>
                <% } else { %>
                    <span class="page-btn disabled">←</span>
                    <% } %>

                        <% for(let i=1; i <=pages; i++) { %>
                            <a href="?page=<%= i %>&sort=<%= sort %>&status=<%= status %>&search=<%= search %>"
                                class="page-btn <%= i === page ? 'active' : '' %>">
                                <%= i %>
                            </a>
                            <% } %>

                                <% if (page < pages) { %>
                                    <a class="page-btn"
                                        href="?page=<%= page+1 %>&sort=<%= sort %>&status=<%= status %>&search=<%= search %>">
                                        →
                                    </a>
                                    <% } else { %>
                                        <span class="page-btn disabled">→</span>
                                        <% } %>

        </div>
        <script src="/javascripts/withdrawalApplication.js"></script>
</body>

</html>