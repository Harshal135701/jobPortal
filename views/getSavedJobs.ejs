<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Saved Jobs</title>
    <link rel="stylesheet" href="/stylesheets/savedJobs.css">
    <link rel="stylesheet" href="/stylesheets/navbar.css">
</head>

<body>

    <%- include("partials/navbar") %>

    <div class="page-wrapper">

        <h2 class="saved-title">Saved Jobs</h2>

        <% if (jobs.length === 0) { %>
            <div class="empty-state">
                <p>No saved jobs yet 🚀</p>
            </div>
        <% } else { %>

        <div class="jobs-container">
            <% jobs.forEach(job => { %>
                <div class="job-card">

                    <div class="job-info">
                        <h3><%= job.title %></h3>
                        <p class="company"><%= job.company %></p>
                        <p class="location"><%= job.location %></p>
                    </div>

                    <div class="job-actions">
                        <a href="/jobs/<%= job._id %>" class="view-btn">View Details</a>
                        <button class="remove-btn" data-id="<%= job._id %>">Remove Bookmark</button>
                    </div>

                </div>
            <% }) %>
        </div>

        <% } %>

    </div>
    <script src="/javascripts/getSavedPost.js"></script>
</body>

</html>